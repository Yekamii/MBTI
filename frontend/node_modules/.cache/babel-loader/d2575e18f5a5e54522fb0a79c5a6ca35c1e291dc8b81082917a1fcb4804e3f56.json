0DE\\u10D8\\u10E0\\u10D0\\u10D3 \\u10E3\\u10E0\\u10D7\\u10D8\\u10D4\\u10E0\\u10D7\\u10DD\\u10D1\\u10D4\\u10D1\\u10E8\\u10D8. \\u10E1\\u10D0\\u10D9\\u10E3\\u10D7\\u10D0\\u10E0\\u10D8 \\u10E1\\u10E2\\u10D8\\u10DA\\u10D8\\u10E1 \\u10EA\\u10DD\\u10D3\\u10DC\\u10D0 \\u10D0\\u10D3\\u10D0\\u10DB\\u10D8\\u10D0\\u10DC\\u10E1 \\u10D4\\u10EE\\u10DB\\u10D0\\u10E0\\u10D4\\u10D1\\u10D0 \\u10EB\\u10DA\\u10D8\\u10D4\\u10E0\\u10D8 \\u10DB\\u10EE\\u10D0\\u10E0\\u10D4\\u10D4\\u10D1\\u10D8\\u10E1 \\u10D2\\u10D0\\u10EA\\u10DC\\u10DD\\u10D1\\u10D8\\u10D4\\u10E0\\u10D4\\u10D1\\u10D0\\u10E1\\u10D0 \\u10D3\\u10D0 \\u10D0\\u10E0\\u10D0\\u10E1\\u10EC\\u10DD\\u10E0\\u10D8 \\u10D7\\u10D5\\u10D8\\u10D7\\u10E8\\u10D4\\u10E4\\u10D0\\u10E1\\u10D4\\u10D1\\u10D8\\u10E1 \\u10D7\\u10D0\\u10D5\\u10D8\\u10D3\\u10D0\\u10DC \\u10D0\\u10EA\\u10D8\\u10DA\\u10D4\\u10D1\\u10D0\\u10E8\\u10D8.\"}),/*#__PURE__*/_jsx(\"h3\",{children:\"\\u10EC\\u10E7\\u10D0\\u10E0\\u10DD\\u10D4\\u10D1\\u10D8\"}),/*#__PURE__*/_jsxs(\"ul\",{className:\"sources\",children:[/*#__PURE__*/_jsx(\"li\",{children:\"Carl Jung (1921)  Psychological Types\"}),/*#__PURE__*/_jsx(\"li\",{children:\"Myers & Myers (1995)  Gifts Differing\"}),/*#__PURE__*/_jsx(\"li\",{children:\"APA Dictionary of Psychology  Decision-making styles\"}),/*#__PURE__*/_jsx(\"li\",{children:\"Kahneman (2011)  Thinking, Fast and Slow\"}),/*#__PURE__*/_jsx(\"li\",{children:\"Damasio (1994)  Descartes Error\"})]})]})});}","map":{"version":3,"names":["jsx","_jsx","jsxs","_jsxs","TFArticle","className","children","src","alt"],"sources":["D:/project-mbti/frontend/src/components/TFArticle.js"],"sourcesContent":["import \"./Article.css\";\r\n\r\nexport default function TFArticle() {\r\n  return (\r\n    <main className=\"article-page\">\r\n      <article className=\"article-container\">\r\n\r\n        <h1 className=\"article-title\">T vs F</h1>\r\n\r\n        <img\r\n          src=\"/tvsf.png\"\r\n          alt=\"Thinking vs Feeling\"\r\n          className=\"article-hero\"\r\n        />\r\n\r\n        <p className=\"lead\">\r\n          Thinking (T) და Feeling (F) აღწერს იმას&#44; როგორ იღებს ადამიანი\r\n          გადაწყვეტილებებს &#8210; რა კრიტერიუმებს ეყრდნობა არჩევანის გაკეთებისას&#46;\r\n          ეს განზომილება არ განსაზღვრავს&#44; ვინ არის &rdquo;უფრო ჭკვიანი&ldquo; ან &rdquo;უფრო ემოციური&ldquo;&#46;\r\n          იგი ასახავს გადაწყვეტილების მიღების ფსიქოლოგიურ პრიორიტეტს&#46;\r\n        </p>\r\n\r\n        <h3>იუნგის თეორიული საფუძველი</h3>\r\n        <p>\r\n          კარლ იუნგის მიხედვით&#44; აზროვნება (Thinking) და გრძნობა&frasl;ღირებულებები\r\n          (Feeling) წარმოადგენს შეფასების ორ განსხვავებულ ფსიქოლოგიურ ფუნქციას&#46;\r\n          Thinking (T) ორიენტირებულია ლოგიკაზე&#44; მიზეზ&#8210;შედეგობრივ კავშირებზე და\r\n          ობიექტურ ანალიზზე&#46;\r\n          Feeling (F) კი ეფუძნება ღირებულებებს&#44; ადამიანურ გავლენას და იმას&#44;\r\n          თუ როგორ აისახება გადაწყვეტილება სხვებზე&#46;\r\n          იუნგი ხაზს უსვამდა&#44; რომ ორივე ფუნქცია აუცილებელია და განსხვავება\r\n          მდგომარეობს იმაში&#44; რომელს ანიჭებს ადამიანი უპირატესობას&#46;\r\n        </p>\r\n        <h3>თანამედროვე ფსიქოლოგიური ხედვა</h3>\r\n        <p>\r\n          თანამედროვე კვლევები აჩვენებს, რომ Thinking და Feeling განსხვავდება\r\n          გადაწყვეტილების მიღების სტილით და არა შესაძლებლობებით&#46;\r\n        </p>\r\n        <ul>\r\n          <li>\r\n            <strong>T ტიპები</strong> ცდილობენ მაქსიმალურ სამართლიანობასა და\r\n            ლოგიკურ თანმიმდევრულობას&#46; მათთვის მნიშვნელოვანია წესები&#44;\r\n            სტანდარტები და ობიექტური კრიტერიუმები&#46;\r\n          </li>\r\n          <li>\r\n            <strong>F ტიპები</strong> ყურადღებას ამახვილებენ ადამიანურ ფაქტორზე &#8210;\r\n            ემოციებზე&#44; ურთიერთობებზე და ინდივიდუალურ საჭიროებებზე&#46;\r\n            მათთვის მნიშვნელოვანია ჰარმონია და ღირებულებებთან შესაბამისობა&#46;\r\n          </li>\r\n          <li>\r\n            ნეიროფსიქოლოგიური კვლევები მიუთითებს&#44; რომ ეს განსხვავება\r\n            დაკავშირებულია ინფორმაციის დამუშავების განსხვავებულ გზებთან\r\n            და არ წარმოადგენს სუსტი ან ძლიერი მხარის ნიშანს&#46;\r\n          </li>\r\n        </ul>\r\n        <p>\r\n          ხშირად არასწორად მიიჩნევა&#44; რომ Thinking ნიშნავს ემოციების არქონას&#44;\r\n          ხოლო Feeling &#8210; არალოგიკურობას&#46;\r\n          რეალურად&#44; T ტიპებსაც აქვთ ემოციები&#44; ხოლო F ტიპებსაც შეუძლიათ\r\n          ლოგიკური ანალიზი &#8210; განსხვავება მხოლოდ იმაშია&#44;\r\n          რას ანიჭებენ ისინი პირველ რიგში მნიშვნელობას გადაწყვეტილების მიღებისას&#46;\r\n          T და F წარმოადგენს გადაწყვეტილების მიღების განსხვავებულ სტილს და\r\n          არა უპირატესობას&#46;\r\n          ეფექტური კომუნიკაცია და თანამშრომლობა ხშირად სწორედ ამ\r\n          განსხვავებების გააზრებაზეა დამოკიდებული &#8210; განსაკუთრებით\r\n          გუნდურ მუშაობასა და პირად ურთიერთობებში&#46;\r\n          საკუთარი სტილის ცოდნა ადამიანს ეხმარება ძლიერი მხარეების\r\n          გაცნობიერებასა და არასწორი თვითშეფასების თავიდან აცილებაში&#46;\r\n        </p>\r\n\r\n        <h3>წყაროები</h3>\r\n        <ul className=\"sources\">\r\n          <li>Carl Jung (1921)  Psychological Types</li>\r\n          <li>Myers & Myers (1995)  Gifts Differing</li>\r\n          <li>APA Dictionary of Psychology  Decision-making styles</li>\r\n          <li>Kahneman (2011)  Thinking, Fast and Slow</li>\r\n          <li>Damasio (1994)  Descartes Error</li>\r\n        </ul>\r\n\r\n      </article>\r\n    </main>\r\n  );\r\n}\r\n"],"mappings":"AAAA,MAAO,eAAe,CAAC,OAAAA,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEvB,cAAe,SAAS,CAAAC,SAASA,CAAA,CAAG,CAClC,mBACEH,IAAA,SAAMI,SAAS,CAAC,cAAc,CAAAC,QAAA,cAC5BH,KAAA,YAASE,SAAS,CAAC,mBAAmB,CAAAC,QAAA,eAEpCL,IAAA,OAAII,SAAS,CAAC,eAAe,CAAAC,QAAA,CAAC,QAAM,CAAI,CAAC,cAEzCL,IAAA,QACEM,GAAG,CAAC,WAAW,CACfC,GAAG,CAAC,qBAAqB,CACzBH,SAAS,CAAC,cAAc,CACzB,CAAC,cAEFJ,IAAA,MAAGI,SAAS,CAAC,MAAM,CAAAC,QAAA,CAAC,2wCAKpB,CAAG,CAAC,cAEJL,IAAA,OAAAK,QAAA,CAAI,8IAAyB,CAAI,CAAC,cA